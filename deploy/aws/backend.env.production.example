APP_NAME=Healthcare Appointment System
ENVIRONMENT=production

DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
DB_POOL_PRE_PING=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800

JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

CORS_ORIGINS=https://your-amplify-domain.amplifyapp.com,https://your-frontend-domain.com
FRONTEND_URL=https://your-amplify-domain.amplifyapp.com

OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_PROVIDER=openai
TRIAGE_USE_LLM=false
TRIAGE_FALLBACK_RULES=true
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384

EMAIL_PROVIDER=brevo
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_API_URL=https://api.brevo.com/v3/smtp/email
SMTP_FROM_EMAIL=appointments@your-verified-domain.com
SMTP_FROM_NAME=Healthcare Appointments
SMTP_TIMEOUT_SECONDS=10

SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
RATE_LIMIT_ENABLED=true
