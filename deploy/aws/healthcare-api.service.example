[Unit]
Description=Healthcare Appointment FastAPI backend
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/healthcare-appointment-system/backend
Environment="PATH=/home/ubuntu/healthcare-appointment-system/backend/venv/bin"
ExecStart=/home/ubuntu/healthcare-appointment-system/backend/venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
